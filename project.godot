; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Juice Demo"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GDAIMCPRuntime="*uid://dcne7ryelpxmn"

[display]

window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Juice Demo"

[editor_plugins]

enabled=PackedStringArray("res://addons/Juice_V1/plugin.cfg", "res://addons/anthonyec.camera_preview/plugin.cfg", "res://addons/gdai-mcp-plugin-godot/plugin.cfg", "res://addons/kenny_spritesheet_importer/plugin.cfg")

